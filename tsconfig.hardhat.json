{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["./hardhat.config.ts", "./test/**/*.ts", "./contracts/**/*.sol"],
  "exclude": ["node_modules"]
}
